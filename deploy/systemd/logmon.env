# Environment file for Logmon services
# Copy to /etc/logmon/logmon.env and adjust paths

# App directory
RAILS_ENV=production
BUNDLE_PATH=/opt/logmon/vendor/bundle

# Caddy logs directory (for import service)
CADDY_LOGS_DIR=/var/log/caddy

# Run the Solid Queue supervisor inside Puma so the dashboard Refresh button
# (which enqueues an import job) is processed. Single-server deployment only.
SOLID_QUEUE_IN_PUMA=1
