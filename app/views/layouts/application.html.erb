<!DOCTYPE html>
<html class="h-full bg-slate-950">
  <head>
    <title><%= content_for(:title) || "Logmon" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Logmon">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "tailwind" %>
    <%= stylesheet_link_tag :app %>
    <%= javascript_importmap_tags %>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
  </head>

  <body class="h-full">
    <div class="min-h-full flex">
      <aside class="w-64 bg-slate-900 border-r border-slate-800 flex flex-col shrink-0">
        <div class="p-6 border-b border-slate-800">
          <h1 class="text-xl font-bold text-white flex items-center gap-2">
            <span class="text-emerald-400">&#9679;</span> Logmon
          </h1>
          <p class="text-xs text-slate-500 mt-1">Caddy Log Monitor</p>
        </div>

        <nav class="flex-1 p-4 space-y-1">
          <%= nav_link "Dashboard", root_path, active: controller_name == "dashboard" %>
          <%= nav_link "Access Logs", access_logs_path, active: controller_name == "access_logs" %>
          <%= nav_link "Error Logs", error_logs_path, active: controller_name == "error_logs" %>
        </nav>

        <div class="p-4 border-t border-slate-800">
          <p class="text-xs text-slate-500">
            <%= AccessLog.count %> access &middot;
            <%= ErrorLog.count %> errors
          </p>
        </div>
      </aside>

      <main class="flex-1 overflow-auto">
        <div class="max-w-7xl mx-auto px-8 py-8">
          <%= yield %>
        </div>
      </main>
    </div>
  </body>
</html>
