<div class="flex items-center justify-center min-h-[calc(100vh-4rem)]">
  <div class="w-full max-w-sm">
    <div class="bg-slate-900 rounded-xl border border-slate-800 p-8">
      <div class="text-center mb-6">
        <h1 class="text-xl font-bold text-white flex items-center justify-center gap-2">
          <span class="text-emerald-400">&#9679;</span> Logmon
        </h1>
        <p class="text-xs text-slate-500 mt-1">Caddy Log Monitor</p>
      </div>

      <% if flash[:alert] %>
        <div class="mb-4 rounded-lg bg-red-950 border border-red-800 px-4 py-3 text-sm text-red-300">
          <%= flash[:alert] %>
        </div>
      <% end %>

      <% if flash[:notice] %>
        <div class="mb-4 rounded-lg bg-emerald-950 border border-emerald-800 px-4 py-3 text-sm text-emerald-300">
          <%= flash[:notice] %>
        </div>
      <% end %>

      <% if @error %>
        <div class="mb-4 rounded-lg bg-amber-950 border border-amber-800 px-4 py-3 text-sm text-amber-300">
          <%= @error %>
        </div>
      <% else %>
        <p class="text-sm text-slate-400 text-center mb-6">Sign in to access the dashboard.</p>

        <div class="space-y-3">
          <% if @authorize_url %>
            <%= link_to @authorize_url, class: "flex items-center justify-center gap-3 w-full px-4 py-3 rounded-lg bg-slate-800 text-white text-sm font-medium hover:bg-slate-700 transition-colors", data: { turbo: false } do %>
              <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 .5C5.37.5 0 5.78 0 12.29c0 5.21 3.44 9.63 8.21 11.19.6.11.82-.26.82-.58 0-.29-.01-1.04-.02-2.05-3.34.72-4.04-1.59-4.04-1.59-.55-1.38-1.34-1.75-1.34-1.75-1.09-.74.08-.73.08-.73 1.2.08 1.84 1.22 1.84 1.22 1.07 1.8 2.81 1.28 3.5.98.11-.76.42-1.28.76-1.57-2.67-.3-5.47-1.31-5.47-5.84 0-1.29.47-2.35 1.23-3.18-.12-.3-.53-1.51.12-3.15 0 0 1-.32 3.3 1.22a11.6 11.6 0 0 1 3-.4c1.02 0 2.05.14 3 .4 2.29-1.54 3.29-1.22 3.29-1.22.66 1.64.24 2.85.12 3.15.77.83 1.23 1.89 1.23 3.18 0 4.54-2.81 5.53-5.49 5.83.43.36.81 1.08.81 2.18 0 1.58-.01 2.85-.01 3.24 0 .32.21.7.83.58A12.04 12.04 0 0 0 24 12.29C24 5.78 18.63.5 12 .5z"/>
              </svg>
              Sign in with GitHub
            <% end %>
          <% end %>

          <% if @authorize_url && @apple_authorize_url %>
            <div class="text-center text-xs text-slate-600 py-1">or</div>
          <% end %>

          <% if @apple_authorize_url %>
            <%= link_to @apple_authorize_url, class: "flex items-center justify-center gap-3 w-full px-4 py-3 rounded-lg bg-white text-black text-sm font-medium hover:bg-slate-200 transition-colors", data: { turbo: false } do %>
              <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.03-.93 3.12-.81 1.57.13 2.7.78 3.4 1.95-3.11 1.87-2.38 5.98.4 7.13-.57 1.5-1.32 2.99-3 3.9zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/>
              </svg>
              Sign in with Apple
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
