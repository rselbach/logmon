<div class="space-y-6">
  <div>
    <%= link_to "&#8592; Back to error logs".html_safe, error_logs_path, class: "text-sm text-slate-400 hover:text-emerald-400" %>
  </div>

  <div class="bg-slate-900 rounded-xl border border-slate-800 p-6 space-y-4">
    <div class="flex items-center gap-3 flex-wrap">
      <%= status_badge(@log.status) %>
      <span class="text-sm text-red-400 font-medium"><%= @log.level %></span>
      <span class="text-sm text-slate-500"><%= @log.source %></span>
    </div>

    <div class="bg-slate-950 rounded-lg p-4 border border-slate-800">
      <p class="text-sm text-slate-300 font-mono"><%= @log.message %></p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <%= detail_row("Timestamp", @log.timestamp&.iso8601) %>
      <%= detail_row("Host", @log.host) %>
      <%= detail_row("Method", @log.method) %>
      <%= detail_row("URI", @log.uri) %>
      <%= detail_row("Remote IP", @log.remote_ip) %>
      <%= detail_row("Duration", @log.duration ? "#{(@log.duration * 1000).round(2)}ms" : nil) %>
      <%= detail_row("Error ID", @log.err_id) %>
      <%= detail_row("Error Trace", @log.err_trace) %>
    </div>
  </div>
</div>
